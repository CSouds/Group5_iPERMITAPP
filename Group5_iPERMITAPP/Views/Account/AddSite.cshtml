@model RESite
@{
    ViewData["Title"] = "Add Site";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0"><i class="bi bi-geo-alt-fill"></i> Add New Site</h4>
            </div>
            <div class="card-body">
                <form asp-action="AddSite" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="SiteAddress" class="form-label"></label>
                        <input asp-for="SiteAddress" class="form-control" placeholder="Full site address" />
                        <span asp-validation-for="SiteAddress" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SiteContactPerson" class="form-label"></label>
                        <input asp-for="SiteContactPerson" class="form-control" placeholder="Contact person at this site" />
                        <span asp-validation-for="SiteContactPerson" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-info text-white">
                        <i class="bi bi-plus-circle"></i> Add Site
                    </button>
                    <a asp-action="Manage" class="btn btn-outline-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
