@model PermitRequest
@{
    ViewData["Title"] = "Review Application";
    var decision = ViewBag.Decision as ReviewDecisionViewModel;
}

<h3><i class="bi bi-clipboard-check"></i> Review Application: @Model.RequestNo</h3>
<hr />

<div class="row">
    <!-- Application Details -->
    <div class="col-md-7">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Application Details</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Request Number:</div>
                    <div class="col-7">@Model.RequestNo</div>
                </div>
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Date of Request:</div>
                    <div class="col-7">@Model.DateOfRequest.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Permit Type:</div>
                    <div class="col-7">@Model.RequestedPermit?.PermitName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Permit Description:</div>
                    <div class="col-7">@Model.RequestedPermit?.Description</div>
                </div>
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Activity Description:</div>
                    <div class="col-7">@Model.ActivityDescription</div>
                </div>
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Activity Start Date:</div>
                    <div class="col-7">@Model.ActivityStartDate.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Activity Duration:</div>
                    <div class="col-7">@Model.ActivityDuration days</div>
                </div>
                <div class="row mb-2">
                    <div class="col-5 fw-bold">Fee Paid:</div>
                    <div class="col-7">$@Model.PermitFee.ToString("F2")
                        @if (Model.Payment != null && Model.Payment.PaymentApproved)
                        {
                            <span class="badge bg-success ms-2">Verified</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Applicant Information -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Applicant Information</h5>
            </div>
            <div class="card-body">
                @if (Model.RequestedBy != null)
                {
                    <div class="row mb-2">
                        <div class="col-5 fw-bold">Organization:</div>
                        <div class="col-7">@Model.RequestedBy.OrganizationName</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 fw-bold">Contact Person:</div>
                        <div class="col-7">@Model.RequestedBy.ContactPersonName</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 fw-bold">Email:</div>
                        <div class="col-7">@Model.RequestedBy.Email</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 fw-bold">Address:</div>
                        <div class="col-7">@Model.RequestedBy.OrganizationAddress</div>
                    </div>
                    @if (Model.RequestedBy.Sites != null && Model.RequestedBy.Sites.Any())
                    {
                        <div class="row mb-2">
                            <div class="col-5 fw-bold">Sites:</div>
                            <div class="col-7">
                                @foreach (var site in Model.RequestedBy.Sites)
                                {
                                    <div class="mb-1">
                                        <i class="bi bi-geo-alt"></i> @site.SiteAddress
                                        <small class="text-muted">(Contact: @site.SiteContactPerson)</small>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Decision Form -->
    <div class="col-md-5">
        <div class="card border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-check2-square"></i> Make Decision</h5>
            </div>
            <div class="card-body">
                <form asp-action="SubmitDecision" method="post">
                    <input type="hidden" name="PermitRequestNo" value="@Model.RequestNo" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Decision</label>
                        <div class="d-grid gap-2">
                            <div class="form-check border rounded p-3">
                                <input class="form-check-input" type="radio" name="FinalDecision"
                                       id="approve" value="Approved" required />
                                <label class="form-check-label text-success fw-bold" for="approve">
                                    <i class="bi bi-check-circle"></i> Approve - Request fulfills all requirements
                                </label>
                            </div>
                            <div class="form-check border rounded p-3">
                                <input class="form-check-input" type="radio" name="FinalDecision"
                                       id="reject" value="Rejected" />
                                <label class="form-check-label text-danger fw-bold" for="reject">
                                    <i class="bi bi-x-circle"></i> Reject - One or more requirements missing
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="Description" class="form-label fw-bold">Reason / Comments</label>
                        <textarea name="Description" id="Description" class="form-control" rows="4"
                                  placeholder="Provide reasoning for your decision..."></textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-send"></i> Submit Decision
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <a asp-action="ReviewApplications" class="btn btn-outline-secondary w-100 mt-3">
            <i class="bi bi-arrow-left"></i> Back to Applications
        </a>
    </div>
</div>
