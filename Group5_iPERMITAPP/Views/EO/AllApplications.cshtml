@model List<PermitRequest>
@{
    ViewData["Title"] = "All Applications";
}

<h3><i class="bi bi-list-ul"></i> All Permit Applications</h3>
<p class="text-muted">Complete list of all submitted permit applications.</p>
<hr />

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Request No</th>
                    <th>Date</th>
                    <th>Applicant</th>
                    <th>Organization</th>
                    <th>Permit Type</th>
                    <th>Fee</th>
                    <th>Payment</th>
                    <th>Current Status</th>
                    <th>Decision</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pr in Model)
                {
                    var status = pr.Statuses?.OrderByDescending(s => s.Date).FirstOrDefault()?.PermitRequestStatus ?? "Unknown";
                    var statusClass = status switch
                    {
                        "Pending Payment" => "status-pending-payment",
                        "Submitted" => "status-submitted",
                        "Being Reviewed" => "status-being-reviewed",
                        "Approved" => "status-approved",
                        "Rejected" => "status-rejected",
                        "Permit Issued" => "status-permit-issued",
                        _ => "bg-secondary text-white"
                    };
                    <tr>
                        <td><strong>@pr.RequestNo</strong></td>
                        <td>@pr.DateOfRequest.ToString("MMM dd, yyyy")</td>
                        <td>@pr.RequestedBy?.ContactPersonName</td>
                        <td>@pr.RequestedBy?.OrganizationName</td>
                        <td>@pr.RequestedPermit?.PermitName</td>
                        <td>$@pr.PermitFee.ToString("F2")</td>
                        <td>
                            @if (pr.Payment != null && pr.Payment.PaymentApproved)
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Unpaid</span>
                            }
                        </td>
                        <td><span class="status-badge @statusClass">@status</span></td>
                        <td>
                            @if (pr.Decision != null)
                            {
                                <span class="badge @(pr.Decision.FinalDecision == "Approved" ? "bg-success" : "bg-danger")">
                                    @pr.Decision.FinalDecision
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="PermitRequest" asp-action="Details" asp-route-id="@pr.RequestNo"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (status == "Submitted" || status == "Being Reviewed")
                            {
                                <a asp-action="Review" asp-route-id="@pr.RequestNo" class="btn btn-sm btn-warning">
                                    <i class="bi bi-clipboard-check"></i>
                                </a>
                            }
                            @if (status == "Approved")
                            {
                                <a asp-action="IssuePermit" asp-route-id="@pr.RequestNo" class="btn btn-sm btn-success">
                                    <i class="bi bi-award"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <p class="text-muted mt-3">No applications found.</p>
    </div>
}
