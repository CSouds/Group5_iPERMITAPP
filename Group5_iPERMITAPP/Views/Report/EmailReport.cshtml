@model List<EmailArchive>
@{
    ViewData["Title"] = "Email Archive Report";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-envelope"></i> Email Archive Report</h3>
    <button class="btn btn-outline-primary no-print" onclick="window.print()">
        <i class="bi bi-printer"></i> Print Report
    </button>
</div>

<div class="alert alert-info">
    <strong>Total Emails Archived:</strong> @Model.Count |
    <strong>Report generated:</strong> @DateTime.Now.ToString("MMMM dd, yyyy HH:mm")
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Email ID</th>
                        <th>Date</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Recipient Email</th>
                        <th>Request No</th>
                        <th>Reason</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int num = 1; }
                    @foreach (var email in Model)
                    {
                        <tr>
                            <td>@num</td>
                            <td><small>@email.EmailID</small></td>
                            <td>@email.EmailDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td><span class="badge bg-primary">@email.SentBy</span></td>
                            <td>@email.SentTo</td>
                            <td><small>@email.RecipientEmail</small></td>
                            <td><strong>@email.PermitRequestNo</strong></td>
                            <td>@(email.Reason.Length > 60 ? email.Reason.Substring(0, 60) + "..." : email.Reason)</td>
                        </tr>
                        num++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
