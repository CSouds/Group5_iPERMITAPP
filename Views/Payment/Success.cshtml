@model Payment
@{
    ViewData["Title"] = "Payment Successful";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card text-center">
            <div class="card-body py-5">
                <i class="bi bi-check-circle-fill display-1 text-success"></i>
                <h2 class="mt-3 text-success">Payment Successful!</h2>
                <p class="text-muted">Your payment has been processed through the OPS Common Payment Portal.</p>

                <hr />

                <div class="text-start mx-auto" style="max-width: 350px;">
                    <div class="row mb-2">
                        <div class="col-6 fw-bold">Payment ID:</div>
                        <div class="col-6">@Model.PaymentID</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6 fw-bold">Request No:</div>
                        <div class="col-6">@Model.PermitRequestNo</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6 fw-bold">Amount:</div>
                        <div class="col-6">$@Model.PermitRequest?.PermitFee.ToString("F2")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6 fw-bold">Method:</div>
                        <div class="col-6">@Model.PaymentMethod ending in @Model.Last4DigitOfCard</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6 fw-bold">Date:</div>
                        <div class="col-6">@Model.PaymentDate.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6 fw-bold">Status:</div>
                        <div class="col-6"><span class="badge bg-success">Approved</span></div>
                    </div>
                </div>

                <hr />

                <div class="alert alert-info">
                    <i class="bi bi-envelope"></i>
                    A confirmation email has been sent to your registered email address.
                    The Environmental Officer has been notified of your completed application.
                </div>

                <a asp-controller="PermitRequest" asp-action="Dashboard" class="btn btn-primary btn-lg">
                    <i class="bi bi-arrow-left"></i> Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
