@model List<PermitRequest>
@{
    ViewData["Title"] = "Review Applications";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h3><i class="bi bi-clipboard-check"></i> Review Submitted Applications</h3>
        <p class="text-muted mb-0">Applications awaiting your review and decision.</p>
    </div>
    <a asp-action="ExportPendingCsv" class="btn btn-outline-success">
        <i class="bi bi-download"></i> Export CSV
    </a>
</div>
<hr />

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th class="col-nowrap">Request No</th>
                    <th class="col-nowrap">Date Submitted</th>
                    <th>Applicant</th>
                    <th>Organization</th>
                    <th>Permit Type</th>
                    <th class="col-nowrap">Fee</th>
                    <th class="col-nowrap">Payment</th>
                    <th class="col-nowrap">Status</th>
                    <th class="col-nowrap">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pr in Model)
                {
                    var status = pr.Statuses?.OrderByDescending(s => s.Date).FirstOrDefault()?.PermitRequestStatus ?? "Unknown";
                    var statusClass = status == "Submitted" ? "status-submitted" : "status-being-reviewed";
                    <tr>
                        <td class="col-nowrap"><strong>@pr.RequestNo</strong></td>
                        <td class="col-nowrap">@pr.DateOfRequest.ToString("MMM dd, yyyy")</td>
                        <td>@pr.RequestedBy?.ContactPersonName</td>
                        <td>@pr.RequestedBy?.OrganizationName</td>
                        <td>@pr.RequestedPermit?.PermitName</td>
                        <td class="col-nowrap">$@pr.PermitFee.ToString("F2")</td>
                        <td class="col-nowrap">
                            @if (pr.Payment != null && pr.Payment.PaymentApproved)
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td class="col-nowrap"><span class="status-badge @statusClass">@status</span></td>
                        <td class="col-nowrap">
                            <a asp-action="Review" asp-route-id="@pr.RequestNo" class="btn btn-sm btn-primary">
                                <i class="bi bi-clipboard-check"></i> Review
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-check-circle display-1 text-success"></i>
        <h4 class="mt-3">All caught up!</h4>
        <p class="text-muted">No applications pending review at this time.</p>
        <a asp-action="Dashboard" class="btn btn-outline-primary">Back to Dashboard</a>
    </div>
}
