@model PermitRequestViewModel
@{
    ViewData["Title"] = "New Permit Application";
    var permitFees = ViewBag.PermitFees as Dictionary<string, double> ?? new Dictionary<string, double>();
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-file-earmark-plus"></i> Environmental Permit Request Form</h4>
            </div>
            <div class="card-body">
                <p class="text-muted">Fill in the details below to apply for an environmental permit.</p>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <h5 class="border-bottom pb-2 mb-3">Permit Selection</h5>
                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="EnvironmentalPermitID" class="form-label"></label>
                            <select asp-for="EnvironmentalPermitID" asp-items="@ViewBag.PermitTypes"
                                    class="form-select" id="permitSelect">
                                <option value="">-- Select a Permit Type --</option>
                            </select>
                            <span asp-validation-for="EnvironmentalPermitID" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Permit Fee</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="text" class="form-control" id="permitFeeDisplay" readonly value="0.00" />
                            </div>
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">Activity Details</h5>
                    <div class="mb-3">
                        <label asp-for="ActivityDescription" class="form-label"></label>
                        <textarea asp-for="ActivityDescription" class="form-control" rows="3"
                                  placeholder="Describe the activity requiring the environmental permit"></textarea>
                        <span asp-validation-for="ActivityDescription" class="text-danger"></span>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="ActivityStartDate" class="form-label"></label>
                            <input asp-for="ActivityStartDate" class="form-control" type="date" />
                            <span asp-validation-for="ActivityStartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ActivityDuration" class="form-label"></label>
                            <input asp-for="ActivityDuration" class="form-control" type="number" min="1" />
                            <span asp-validation-for="ActivityDuration" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SiteID" class="form-label"></label>
                            <select asp-for="SiteID" asp-items="@ViewBag.Sites" class="form-select">
                                <option value="">-- Select Site --</option>
                            </select>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        After submitting, you will be directed to the <strong>OPS Common Payment Portal</strong> to pay the application fee.
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-send"></i> Submit Application
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Dynamically show the permit fee when a permit type is selected
        var permitFees = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(permitFees));
        document.getElementById('permitSelect').addEventListener('change', function() {
            var fee = permitFees[this.value] || 0;
            document.getElementById('permitFeeDisplay').value = fee.toFixed(2);
        });
    </script>
}
