@model PermitRequest
@{
    ViewData["Title"] = "Request Details";
    var latestStatus = Model.Statuses?.OrderByDescending(s => s.Date).FirstOrDefault()?.PermitRequestStatus ?? "Unknown";
    var statusClass = latestStatus switch
    {
        "Pending Payment" => "status-pending-payment",
        "Submitted" => "status-submitted",
        "Being Reviewed" => "status-being-reviewed",
        "Approved" => "status-approved",
        "Rejected" => "status-rejected",
        "Permit Issued" => "status-permit-issued",
        _ => "bg-secondary text-white"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="bi bi-file-earmark-text"></i> Request: @Model.RequestNo</h3>
    <div>
        <span class="status-badge @statusClass fs-5 me-2">@latestStatus</span>
        <button class="btn btn-outline-primary no-print" onclick="window.print()">
            <i class="bi bi-printer"></i> Print
        </button>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <!-- Request Details -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Application Details</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-md-4 fw-bold">Request Number:</div>
                    <div class="col-md-8">@Model.RequestNo</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-bold">Date of Request:</div>
                    <div class="col-md-8">@Model.DateOfRequest.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-bold">Permit Type:</div>
                    <div class="col-md-8">@Model.RequestedPermit?.PermitName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-bold">Activity Description:</div>
                    <div class="col-md-8">@Model.ActivityDescription</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-bold">Activity Start Date:</div>
                    <div class="col-md-8">@Model.ActivityStartDate.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-bold">Activity Duration:</div>
                    <div class="col-md-8">
                        @Model.ActivityDuration days
                        @if (Model.IssuedPermit != null && Model.IssuedPermit.Duration != $"{Model.ActivityDuration} days")
                        {
                            <span class="badge bg-info ms-2">Issued: @Model.IssuedPermit.Duration</span>
                        }
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-bold">Permit Fee:</div>
                    <div class="col-md-8">$@Model.PermitFee.ToString("F2")</div>
                </div>
                @if (Model.RequestedBy != null)
                {
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Applicant:</div>
                        <div class="col-md-8">@Model.RequestedBy.OrganizationName (@Model.RequestedBy.ContactPersonName)</div>
                    </div>
                }
            </div>
        </div>

        <!-- Payment Info -->
        @if (Model.Payment != null)
        {
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-credit-card"></i> Payment Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Payment ID:</div>
                        <div class="col-md-8">@Model.Payment.PaymentID</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Date:</div>
                        <div class="col-md-8">@Model.Payment.PaymentDate.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Method:</div>
                        <div class="col-md-8">@Model.Payment.PaymentMethod ending in @Model.Payment.Last4DigitOfCard</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Status:</div>
                        <div class="col-md-8">
                            @if (Model.Payment.PaymentApproved)
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Declined</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Decision Info -->
        @if (Model.Decision != null)
        {
            <div class="card mb-4">
                <div class="card-header @(Model.Decision.FinalDecision == "Approved" ? "bg-success" : "bg-danger") text-white">
                    <h5 class="mb-0"><i class="bi bi-check2-circle"></i> EO Decision</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Decision:</div>
                        <div class="col-md-8">
                            <span class="badge @(Model.Decision.FinalDecision == "Approved" ? "bg-success" : "bg-danger") fs-6">
                                @Model.Decision.FinalDecision
                            </span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Date:</div>
                        <div class="col-md-8">@Model.Decision.DateOfDecision.ToString("MMMM dd, yyyy")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Decision.Description))
                    {
                        <div class="row mb-2">
                            <div class="col-md-4 fw-bold">Reason:</div>
                            <div class="col-md-8">@Model.Decision.Description</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Issued Permit -->
        @if (Model.IssuedPermit != null)
        {
            <div class="card mb-4 border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-award"></i> Issued Permit</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Permit ID:</div>
                        <div class="col-md-8">@Model.IssuedPermit.PermitID</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Date of Issue:</div>
                        <div class="col-md-8">@Model.IssuedPermit.DateOfIssue.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Duration:</div>
                        <div class="col-md-8">@Model.IssuedPermit.Duration</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-bold">Description:</div>
                        <div class="col-md-8">@Model.IssuedPermit.Description</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Status Timeline -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Status History</h5>
            </div>
            <div class="card-body">
                @if (Model.Statuses != null && Model.Statuses.Any())
                {
                    @foreach (var status in Model.Statuses.OrderByDescending(s => s.Date))
                    {
                        var sClass = status.PermitRequestStatus switch
                        {
                            "Pending Payment" => "border-warning",
                            "Submitted" => "border-primary",
                            "Being Reviewed" => "border-info",
                            "Approved" => "border-success",
                            "Rejected" => "border-danger",
                            "Permit Issued" => "border-success",
                            _ => "border-secondary"
                        };
                        <div class="border-start border-3 @sClass ps-3 mb-3">
                            <strong>@status.PermitRequestStatus</strong><br />
                            <small class="text-muted">@status.Date.ToString("MMM dd, yyyy HH:mm")</small><br />
                            <small>@status.Description</small>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="mt-3">
            @if (latestStatus == "Pending Payment")
            {
                <a asp-controller="Payment" asp-action="Pay" asp-route-requestNo="@Model.RequestNo"
                   class="btn btn-warning w-100 mb-2">
                    <i class="bi bi-credit-card"></i> Proceed to Payment
                </a>
            }
            @if (Context.Session.GetString("UserRole") == "EO")
            {
                <a asp-controller="EO" asp-action="Dashboard" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
            }
            else
            {
                <a asp-controller="PermitRequest" asp-action="Dashboard" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
            }
        </div>
    </div>
</div>
