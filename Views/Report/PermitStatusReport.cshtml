@model List<PermitRequest>
@{
    ViewData["Title"] = "Permit Status Report";
    var statusCounts = ViewBag.StatusCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var totalApps = ViewBag.TotalApplications as int? ?? 0;
    var totalRevenue = ViewBag.TotalRevenue as double? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-file-earmark-bar-graph"></i> Permit Status Report</h3>
    <button class="btn btn-outline-primary no-print" onclick="window.print()">
        <i class="bi bi-printer"></i> Print Report
    </button>
</div>

<div class="alert alert-info">
    <strong>Report generated:</strong> @DateTime.Now.ToString("MMMM dd, yyyy HH:mm") |
    <strong>EO Only</strong> - This report is restricted to Environmental Officer access.
</div>

<!-- Summary Statistics -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card bg-primary text-white">
            <div class="stat-number">@totalApps</div>
            <div class="stat-label text-white-50">Total Applications</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-success text-white">
            <div class="stat-number">$@totalRevenue.ToString("N2")</div>
            <div class="stat-label text-white-50">Total Revenue</div>
        </div>
    </div>
    @foreach (var sc in statusCounts)
    {
        var bgColor = sc.Key switch
        {
            "Pending Payment" => "bg-warning text-dark",
            "Submitted" => "bg-info text-white",
            "Being Reviewed" => "bg-secondary text-white",
            "Approved" => "bg-success text-white",
            "Rejected" => "bg-danger text-white",
            "Permit Issued" => "bg-success text-white",
            _ => "bg-secondary text-white"
        };
        <div class="col-md-2">
            <div class="card stat-card @bgColor">
                <div class="stat-number">@sc.Value</div>
                <div class="stat-label">@sc.Key</div>
            </div>
        </div>
    }
</div>

<!-- Detailed Report Table -->
<div class="card">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">All Submitted Permits and Their Status</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Request No</th>
                        <th>Date</th>
                        <th>Organization</th>
                        <th>Contact</th>
                        <th>Permit Type</th>
                        <th>Activity</th>
                        <th>Fee</th>
                        <th>Payment</th>
                        <th>Current Status</th>
                        <th>Decision</th>
                        <th>Permit Issued</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rowNum = 1; }
                    @foreach (var pr in Model)
                    {
                        var status = pr.Statuses?.OrderByDescending(s => s.Date).FirstOrDefault()?.PermitRequestStatus ?? "Unknown";
                        var statusClass = status switch
                        {
                            "Pending Payment" => "status-pending-payment",
                            "Submitted" => "status-submitted",
                            "Being Reviewed" => "status-being-reviewed",
                            "Approved" => "status-approved",
                            "Rejected" => "status-rejected",
                            "Permit Issued" => "status-permit-issued",
                            _ => "bg-secondary text-white"
                        };
                        <tr>
                            <td>@rowNum</td>
                            <td><strong>@pr.RequestNo</strong></td>
                            <td>@pr.DateOfRequest.ToString("MMM dd, yyyy")</td>
                            <td>@pr.RequestedBy?.OrganizationName</td>
                            <td>@pr.RequestedBy?.ContactPersonName</td>
                            <td>@pr.RequestedPermit?.PermitName</td>
                            <td>@(pr.ActivityDescription.Length > 30 ? pr.ActivityDescription.Substring(0, 30) + "..." : pr.ActivityDescription)</td>
                            <td>$@pr.PermitFee.ToString("F2")</td>
                            <td>
                                @if (pr.Payment != null && pr.Payment.PaymentApproved)
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Unpaid</span>
                                }
                            </td>
                            <td><span class="status-badge @statusClass">@status</span></td>
                            <td>
                                @if (pr.Decision != null)
                                {
                                    <span class="badge @(pr.Decision.FinalDecision == "Approved" ? "bg-success" : "bg-danger")">
                                        @pr.Decision.FinalDecision
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Pending</span>
                                }
                            </td>
                            <td>
                                @if (pr.IssuedPermit != null)
                                {
                                    <span class="badge bg-success">@pr.IssuedPermit.PermitID</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                        rowNum++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
