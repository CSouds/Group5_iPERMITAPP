@model IEnumerable<iPERMIT_Group_5.Models.Permit>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.issueDate)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.EO.Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.RE.contactPersonName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.PermitRequest.activityDescription)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.issueDate)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.EO.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.RE.contactPersonName)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.PermitRequest.activityDescription)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.PermitID }) |
            @Html.ActionLink("Details", "Details", new { id=item.PermitID }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.PermitID })
        </td>
    </tr>
}

</table>
